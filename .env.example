# LiteLLM API port on host
LITELLM_PORT=4000

# Direct path to llama-server binary. Leave empty to auto-detect.
LLAMA_SERVER_BIN=

# GPU layers for llama.cpp fast profile.
# 0 = CPU-only. AMD Radeon Pro 5600M on Intel Mac x86_64 does not work with Metal compute.
# brew llama-server 9430 was built without Metal (ngl is ignored).
# Custom build 9538 (5343f4502) has broken Metal blk-kernels — garbled output at ngl>0.
# For GPU acceleration, Apple Silicon Mac (M1/M2/M3/M4) is required.
FAST_NGL=0

# Postgres for LiteLLM UI/admin features
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm

# Master API key — used in Authorization: Bearer <key>
# Change before any external access
LITELLM_MASTER_KEY=sk-local-change-me

# UI credentials — login/password for http://localhost:4000/ui
UI_USERNAME=admin
UI_PASSWORD=changeme

# Open WebUI
OPENWEBUI_PORT=3000
WEBUI_AUTH=False

# By default Open WebUI connects directly to llama.cpp (fast)
OPENWEBUI_API_BASE_URL=http://host.docker.internal:8080/v1
OPENWEBUI_API_KEY=dummy

# To route through LiteLLM instead, use:
# OPENWEBUI_API_BASE_URL=http://litellm:4000/v1
# OPENWEBUI_API_KEY=sk-local-change-me

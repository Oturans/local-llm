# LiteLLM API port on host
LITELLM_PORT=4000

# Postgres for LiteLLM UI/admin features
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm

# Master API key — используется в Authorization: Bearer <key>
# Задай свой ключ перед использованием
LITELLM_MASTER_KEY=sk-local-change-me

# UI credentials — логин/пароль для http://localhost:4000/ui
UI_USERNAME=admin
UI_PASSWORD=changeme
